+_OPERATOR_AHEAD_BLOCK = """\
+OPERATOR MODE (10-steps-ahead):
+- Surface what the market has NOT priced in yet — second-order effects, flywheel touches left idle,
+  speed-to-lead gaps, and decisions Lindsey's own history might reflex-skip but math supports.
+- Separate: what matters in the next 24h vs 72h vs 30 days.
+- Name the contrarian move vs what a typical operator would do — she still decides.
+- Never invent dollar amounts; use engine_output when present."""
+
+
+def _operator_mode_query(message: str) -> bool:
+    q = (message or "").lower()
+    triggers = (
+        "10 step",
+        "ten step",
+        "ahead",
+        "contrarian",
+        "edge",
+        "what am i missing",
+        "what are they missing",
+        "horizon",
+        "future",
+        "corner",
+    )
+    return any(t in q for t in triggers)
+
+
 def _retrieve(kb, message: str) -> dict:
     """Pull relevant memory for grounding. Safe if kb is None or empty."""
     out = {"voice": [], "decisions": [], "knowledge": [], "conversation_patterns": []}
