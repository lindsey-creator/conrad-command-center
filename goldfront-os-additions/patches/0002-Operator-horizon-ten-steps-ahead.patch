new file mode 100644
index 0000000..0c2b13f
--- /dev/null
+++ b/tests/test_horizon.py
@@ -0,0 +1,15 @@
+"""Operator horizon intel."""
+
+from brain.council.horizon import operator_horizon
+from tests.test_council import FakeCockpit
+
+
+def test_operator_horizon_shape():
+    out = operator_horizon(FakeCockpit())
+    assert out["status"] in ("ok", "partial")
+    assert "signals" in out
+    assert "now" in out["signals"]
+    assert "edge_72h" in out["signals"]
+    assert "horizon_30d" in out["signals"]
+    assert len(out.get("contrarian") or []) >= 1
+    assert 0 <= out.get("readiness_score", 0) <= 100
