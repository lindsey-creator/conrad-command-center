@@ -147,6 +148,20 @@ def intel_snapshot():
     return build_live_context(_cockpit)
 
 
+@app.get("/intel/horizon")
+def intel_horizon(narrate: bool = False):
+    """
+    Operator horizon — now / 72h edge / 30d structural signals + contrarian board.
+    Optional ?narrate=1 for one-paragraph Claude briefing (needs ANTHROPIC_API_KEY).
+    """
+    payload = operator_horizon(_cockpit)
+    if narrate:
+        narration = narrate_horizon(payload)
+        if narration:
+            payload["narration"] = narration
+    return payload
+
+
 @app.get("/deals/pipeline")
 def deals_pipeline():
     """Reference pipeline cards (master spec seed deals) — qualitative, no invented math."""
