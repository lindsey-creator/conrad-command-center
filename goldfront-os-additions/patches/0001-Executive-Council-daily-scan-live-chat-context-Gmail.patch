@@ -0,0 +1,62 @@
+"""Live cockpit snapshot injected into every /chat call (Superman Brain grounding)."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+
+from brain.connectors import clickup, ghl, meta
+from brain.council.orchestrator import daily_money_scan
+
+
+def _compact(obj: Any, max_len: int = 4000) -> str:
+    raw = json.dumps(obj, default=str, ensure_ascii=False)
+    if len(raw) <= max_len:
+        return raw
+    return raw[: max_len - 3] + "…"
+
+
+def build_live_context(cockpit_read) -> dict:
+    """
+    Pull a bounded snapshot of what the Command Center knows right now.
+    Safe when connectors are down — sections simply omit or mark connect_source.
+    """
+    ctx: dict = {"generated_by": "superman_brain_live_context"}
+
+    try:
+        ctx["connectors"] = {
+            "clickup": clickup.configured(),
+            "ghl": ghl.configured(),
+            "meta": meta.configured(),
+        }
+    except Exception:
+        ctx["connectors"] = {}
+
+    for key, fn in (
+        ("watchlist", cockpit_read.watchlist),
+        ("team_pulse", cockpit_read.team_pulse),
+        ("top_moves", lambda: daily_money_scan(cockpit_read)),
+        ("blindspots", cockpit_read.blindspots),
+        ("ghl_crm", cockpit_read.ghl_crm),
+        ("brief_headline", lambda: {"headline": daily_money_scan(cockpit_read).get("headline")}),
+    ):
+        try:
+            ctx[key] = fn()
+        except Exception as exc:
+            ctx[key] = {"status": "error", "error": str(exc)[:200]}
+
+    try:
+        ctx["train_counts"] = cockpit_read.counts()
+    except Exception:
+        pass
+
+    return ctx
+
+
+def format_context_for_model(ctx: dict) -> str:
+    """Human-readable block for Claude — authoritative for ops, not for deal math."""
+    return (
+        "LIVE COMMAND CENTER SNAPSHOT (connector data — use for priorities and follow-ups; "
+        "deal math still comes only from engine_output when provided):\n"
+        f"{_compact(ctx)}"
+    )
