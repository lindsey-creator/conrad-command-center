+        [r"\bwellbeing\b", r"\bstress\b", r"\btherapy\b", r"\bburnout\b"],
+    ),
+]
+
+
+def route_seats(message: str, max_seats: int = 4) -> list[SeatId]:
+    """Pick council seats by keyword patterns; Chief of Staff always included."""
+    text = (message or "").lower()
+    scored: list[tuple[int, SeatId]] = []
+    for seat in COUNCIL_SEATS:
+        if seat.id == "chief_of_staff":
+            continue
+        score = 0
+        for pat in seat.patterns:
+            if re.search(pat, text, re.I):
+                score += 2
+        if score:
+            scored.append((score, seat.id))
+    scored.sort(key=lambda x: -x[0])
+    picked: list[SeatId] = ["chief_of_staff"]
+    for _, sid in scored[: max_seats - 1]:
+        if sid not in picked:
+            picked.append(sid)
+    if len(picked) == 1:
+        picked.extend(["deal_hunter", "people_coo"])
+    return picked[:max_seats]
+
+
+def seat_prompt_block(seat_ids: list[SeatId]) -> str:
+    lines = [
+        "EXECUTIVE COUNCIL (synthesize one clear answer — do not role-play separate voices unless asked):",
+        "You are the Chief of Staff orchestrating these seats for this question:",
+    ]
+    by_id = {s.id: s for s in COUNCIL_SEATS}
+    for sid in seat_ids:
+        s = by_id.get(sid)
+        if s:
+            lines.append(f"- {s.title}: {s.lens}")
+    lines.append(
+        "Deliver one unified recommendation. Name which seat drove the key insight when it matters."
+    )
+    return "\n".join(lines)
