+"""Council seat definitions and lightweight routing (no extra model calls)."""
+
+from __future__ import annotations
+
+import re
+from typing import Literal
+
+SeatId = Literal[
+    "chief_of_staff",
+    "cfo_capital",
+    "deal_hunter",
+    "flywheel_officer",
+    "rainmaker",
+    "risk_compliance",
+    "people_coo",
+    "performance",
+    "wellbeing",
+]
+
+
+class _Seat:
+    __slots__ = ("id", "title", "lens", "patterns")
+
+    def __init__(self, id: SeatId, title: str, lens: str, patterns: list[str]):
+        self.id = id
+        self.title = title
+        self.lens = lens
+        self.patterns = patterns
+
+
+COUNCIL_SEATS: list[_Seat] = [
+    _Seat(
+        "chief_of_staff",
+        "Chief of Staff",
+        "Prioritize Lindsey's attention; surface the 3 things that matter today.",
+        [r"\btoday\b", r"\btop\s*3\b", r"\bpriorit", r"\bbrief\b", r"\bwhat\s+first\b"],
+    ),
+    _Seat(
+        "cfo_capital",
+        "CFO / Capital",
+        "Margin vs ARV, DSCR, capital stack (Joe vs Goldfront vs CB3 takeout). Never invent numbers.",
+        [r"\bdscr\b", r"\bmargin\b", r"\bcapital\b", r"\bstack\b", r"\bcb3\b", r"\bunderwater\b"],
+    ),
+    _Seat(
+        "deal_hunter",
