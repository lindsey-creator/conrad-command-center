@@ -0,0 +1,197 @@
+"""
+Daily money scan + ranked moves (Executive Council § daily money scan).
+
+Heuristic-first: works without Anthropic. Uses live connectors + seed pipeline +
+memory — never invents dollar amounts (master spec §3.1).
+"""
+
+from __future__ import annotations
+
+from brain.cockpit.seed_pipeline import SEED_DEALS
+
+
+def _move(
+    title: str,
+    why: str,
+    action: str,
+    *,
+    seat: str,
+    deal_ref: str | None = None,
+    priority: int = 50,
+) -> dict:
+    return {
+        "title": title,
+        "dollars": None,
+        "why": why,
+        "recommended_action": action,
+        "deal_ref": deal_ref,
+        "council_seat": seat,
+        "priority": priority,
+    }
+
+
+def daily_money_scan(cockpit_read) -> dict:
+    """
+    `cockpit_read` is a CockpitRead instance.
+    Returns { status, sources, moves, watch_count, headline, seats_active }.
+    """
+    moves: list[dict] = []
+    sources: list[str] = []
+    watch_count = 0
+
+    # --- Live: GHL / revenue fire ---
+    try:
+        ghl = cockpit_read.ghl_crm()
+        if ghl.get("status") == "ok":
+            sources.append("ghl")
+            unread = int(ghl.get("unread_texts") or 0)
+            missed = int(ghl.get("missed_calls") or 0)
+            leads = int(ghl.get("new_leads") or 0)
+            if unread or missed or leads:
+                moves.append(
+                    _move(
+                        "Meta → GHL speed-to-lead",
+                        f"{leads} recent contacts · {unread} unread SMS · {missed} missed calls.",
+                        "Clear inbox + call back hot leads before ad spend cools.",
+                        seat="rainmaker",
+                        priority=90 if unread or missed else 70,
+                    )
+                )
+    except Exception:
+        pass
+
+    # --- Live: overdue / ops ---
+    try:
+        pulse = cockpit_read.team_pulse()
+        if pulse.get("status") == "ok":
+            sources.append("clickup")
+            overdue = pulse.get("overdue") or []
+            watch_count += len(overdue)
+            for t in overdue[:2]:
+                moves.append(
+                    _move(
+                        f"{t.get('person', 'Team')}: {t.get('task', 'Overdue task')}",
+                        f"{t.get('days_late', '?')} days late — accountability gap.",
+                        "Assign or close in ClickUp today; follow up on Fieldy commitment if any.",
+                        seat="people_coo",
+                        priority=85 + min(int(t.get("days_late") or 0), 10),
+                    )
+                )
+    except Exception:
+        pass
+
+    # --- Seed pipeline idle flags (always available as strategic spine) ---
+    sources.append("brain_pipeline")
+    for deal in SEED_DEALS:
+        idle = int(deal.get("idle_days") or 0)
+        if idle >= 7:
+            moves.append(
+                _move(
+                    f"{deal['name']} — {deal['address']}",
+                    f"{idle}d idle · {deal.get('flywheel_live', 0)} flywheel touches live. {deal.get('note', '')}",
+                    "One decision today: comps, structure, or kill — do not let this drift.",
+                    seat="deal_hunter" if idle < 10 else "chief_of_staff",
+                    deal_ref=deal.get("address"),
+                    priority=95 if idle >= 9 else 80,
+                )
+            )
+        elif idle >= 4:
+            moves.append(
+                _move(
+                    f"{deal['name']} slipping",
+                    deal.get("note", ""),
+                    "15-minute owner ping — confirm next milestone date.",
+                    seat="flywheel_officer",
+                    deal_ref=deal.get("address"),
+                    priority=60,
+                )
+            )
+
+    # --- Meta ads connector ---
+    try:
+        ads = cockpit_read.meta_ads()
+        if ads.get("status") == "connect_source":
+            moves.append(
+                _move(
+                    "Connect Meta Ads",
+                    "Daily spend and CPL are blind without Meta — #1 investor lead fire stays dark.",
+                    "Add Meta token in Stack → Connections; tie to GHL capture.",
+                    seat="cfo_capital",
+                    priority=75,
+                )
+            )
+        elif ads.get("status") == "ok":
+            sources.append("meta")
+            cpl = ads.get("cost_per_lead")
+            if cpl is not None:
+                moves.append(
+                    _move(
+                        "Meta investor ads",
+                        f"Spend {ads.get('daily_spend', '—')} · CPL {cpl} · leads {ads.get('leads', '—')}.",
+                        "If CPL rising, refresh creative or tighten GHL speed-to-lead.",
+                        seat="rainmaker",
+                        priority=65,
+                    )
+                )
+    except Exception:
+        pass
+
+    # --- Trained decisions (memory) ---
+    try:
+        kb = cockpit_read.kb
+        for d in kb.decisions_history(limit=2):
+            meta = d.get("metadata", {})
+            addr = meta.get("address")
+            if not addr:
+                continue
+            sources.append("brain_memory")
+            moves.append(
+                _move(
+                    f"Trained call: {addr}",
+                    (meta.get("reasoning") or d.get("text", ""))[:180],
+                    f"Prior verdict {meta.get('verdict', '—')} — reconcile with today's pipeline.",
+                    seat="deal_hunter",
+                    deal_ref=addr,
+                    priority=55,
+                )
+            )
+    except Exception:
+        pass
+
+    # Dedupe by title, sort by priority
+    seen: set[str] = set()
+    unique: list[dict] = []
+    for m in sorted(moves, key=lambda x: -int(x.get("priority") or 0)):
+        key = m["title"][:80]
+        if key in seen:
+            continue
+        seen.add(key)
+        m.pop("priority", None)
+        unique.append(m)
+
+    unique = unique[:3]
+    seats_active = sorted({m.get("council_seat") for m in unique if m.get("council_seat")})
+
+    if unique:
+        status = "ok"
+    elif sources:
+        status = "partial"
+    else:
+        status = "connect_source"
+
+    headline = (
+        f"{watch_count} operational {'alert' if watch_count == 1 else 'alerts'} — council ranked {len(unique)} moves."
+        if watch_count
+        else f"Council ranked {len(unique)} money moves for today."
+    )
+
+    return {
+        "status": status,
+        "sources": sorted(set(sources)),
+        "moves": unique,
+        "limit": 3,
+        "watch_count": watch_count,
+        "headline": headline,
+        "seats_active": seats_active,
+        "decisions_known": cockpit_read.counts().get("decisions", 0),
+    }
